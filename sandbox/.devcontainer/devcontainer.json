{
  "name": "Sandbox",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/devcontainers/features/node:2": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "./config": {}
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/usr/bin/zsh"
          }
        }
      },
      "extensions": []
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.zsh_secrets,target=/home/vscode/.zsh_secrets,type=bind"
  ],
  "postCreateCommand": "echo 'Sandbox dev container is ready!'",
  "remoteUser": "vscode"
}